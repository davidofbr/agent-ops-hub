# DataForSEO — required
# Basic auth with login + password (not a single API key).
# Get credentials at https://app.dataforseo.com/api-access — the API
# password is auto-generated and differs from your account password.
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# Jina Reader — optional
# Without a key, r.jina.ai works but rate-limits more aggressively.
# Get a key at https://jina.ai/reader — free tier is generous.
JINA_API_KEY=
